// Logistics ERP & CRM — normalized relational schema (PostgreSQL)
//
// Design notes
// - Every business document (quotation, job) references master data by FK;
//   nothing is duplicated except immutable snapshot fields needed for audit
//   (e.g. quotation item cost at time of quoting).
// - Money is stored as Decimal(14,2); rates/factors as Decimal(14,6).
// - Codes (CUST-0001, QT-2026-0001...) are generated from the Sequence table
//   so prefixes/padding stay configurable, never hardcoded.
// - Future modules (invoices, purchase orders, accounting) can attach to
//   Quotation/Job/Customer/Vendor without schema redesign.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Auth & RBAC ───────────────────────────

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  fullName     String
  phone        String? // shown as the salesperson contact on printed quotations
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  isActive     Boolean    @default(true)
  // Account-level brute-force lockout (IP throttling alone is bypassable
  // by rotating IPs): N failures lock the account until lockedUntil.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  quotations        Quotation[]        @relation("SalesPerson")
  vendorRatings     VendorRating[]
  customerRatings   CustomerRating[]
  notifications     Notification[]
  jobTrackingEvents JobTrackingEvent[]
  invoicePayments   InvoicePayment[]
  quotationRevisions QuotationRevision[]
  quotationApprovals Quotation[]       @relation("QuotationApprover")
  customersAssigned  Customer[]        @relation("CustomerSalesperson")
  customersCreated   Customer[]        @relation("CustomerCreatedBy")
  customersUpdated   Customer[]        @relation("CustomerUpdatedBy")
  vendorsAssigned    Vendor[]          @relation("VendorBuyer")
  vendorsCreated     Vendor[]          @relation("VendorCreatedBy")
  vendorsUpdated     Vendor[]          @relation("VendorUpdatedBy")

  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique // Administrator, Manager, Sales, Operation, Finance, Viewer
  description String?
  isSystem    Boolean          @default(false)
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id    String           @id @default(uuid())
  code  String           @unique // e.g. "customers.read", "quotations.write"
  label String
  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─────────────────────────── Master data ───────────────────────────

enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum CustomerType {
  COMPANY
  INDIVIDUAL
}

model Customer {
  id           String       @id @default(uuid())
  code         String       @unique // auto: CUST-0001
  companyName  String
  // ── Primary contact (denormalized quick-reference; full list in contacts[]) ──
  pic          String? // person in charge / primary contact name
  phone        String? // primary office phone
  email        String?
  mobile       String?
  officePhone  String?
  extension    String?
  whatsapp     String?
  contactTitle String? // primary contact job title
  preferredComm String? // EMAIL / PHONE / WHATSAPP / SMS
  // ── Company information ──
  address       String? // legacy single-line address (kept; full list in addresses[])
  industry      String?
  customerType  CustomerType @default(COMPANY)
  registrationNo String? // business registration / SSM number
  taxId         String? // GST / VAT / SST number
  website       String?
  customerCategory String? // e.g. Wholesale / Retail / Government
  salesTerritory   String?
  leadSource       String? // Referral / Website / Cold Call / Exhibition...
  // ── Financial ──
  paymentTerm     String? // e.g. "NET 30"
  creditLimit     Decimal?     @db.Decimal(14, 2)
  outstandingLimit Decimal?    @db.Decimal(14, 2)
  currency        String?      @default("MYR")
  priceLevel      String?
  taxType         String? // SST / GST / EXEMPT / ZERO-RATED
  taxExempt       Boolean      @default(false)
  creditHold      Boolean      @default(false) // block new orders when true
  openingBalance  Decimal?     @db.Decimal(14, 2)
  openingBalanceDate DateTime?
  // ── Sales & operations ──
  assignedSalespersonId String?
  assignedSalesperson   User?  @relation("CustomerSalesperson", fields: [assignedSalespersonId], references: [id], onDelete: SetNull)
  salesTeam        String?
  discountGroup    String?
  defaultDiscountPct Decimal?   @db.Decimal(7, 4)
  commissionGroup  String?
  defaultWarehouse String?
  preferredDeliveryMethod String?
  preferredShippingCompany String?
  // ── Accounting ──
  arAccount           String?
  customerAccountCode String?
  taxCategory         String?
  financeRemarks      String?
  // ── Shipping ──
  deliveryInstructions String?
  receivingHours       String?
  loadingBayNotes      String?
  preferredCourier     String?
  shippingNotes        String?
  // ── CRM ──
  status       EntityStatus @default(ACTIVE) // account status (kept)
  priority     Int          @default(3) // 1 highest .. 5 lowest (kept)
  leadStatus       String? // NEW / QUALIFIED / PROPOSAL / WON / LOST
  firstContactDate DateTime?
  customerSince    DateTime?
  lastContactDate  DateTime?
  lastSalesDate    DateTime?
  nextFollowUp     DateTime?
  birthday         DateTime? // for individuals
  companyAnniversary DateTime?
  // ── Preferences ──
  preferredLanguage String?
  timeZone          String?
  receivePromotions      Boolean @default(true)
  receiveStatementsByEmail Boolean @default(true)
  receiveInvoiceByEmail    Boolean @default(true)
  // ── Internal ──
  notes            String? // general internal notes (kept)
  creditNotesInternal String? // financial/credit remarks (distinct from AR credit notes)
  collectionNotes  String?
  customerWarnings String?
  blacklist        Boolean @default(false)
  vip              Boolean @default(false)
  // ── System ──
  createdById   String?
  createdBy     User?     @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById   String?
  updatedBy     User?     @relation("CustomerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedAt    DateTime? // soft delete — non-null means in the recycle bin
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  quotations Quotation[]
  jobs       Job[]
  ratings    CustomerRating[]
  invoices   Invoice[]
  contacts     CustomerContact[]
  addresses    CustomerAddress[]
  documents    CustomerDocument[]
  bankAccounts CustomerBankAccount[]

  @@index([companyName])
  @@index([deletedAt])
  @@index([assignedSalespersonId])
  @@map("customers")
}

model CustomerContact {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  position   String?
  department String?
  mobile     String?
  phone      String?
  email      String?
  remarks    String?
  sortOrder  Int      @default(0)

  @@index([customerId])
  @@map("customer_contacts")
}

enum AddressType {
  REGISTERED
  BILLING
  SHIPPING
  WAREHOUSE
}

model CustomerAddress {
  id         String      @id @default(uuid())
  customerId String
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       AddressType @default(BILLING)
  line1      String?
  line2      String?
  city       String?
  state      String?
  postalCode String?
  country    String?     @default("Malaysia")
  isPrimary  Boolean     @default(false)
  sortOrder  Int         @default(0)

  @@index([customerId])
  @@map("customer_addresses")
}

model CustomerDocument {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  category   String? // Business Registration / Tax Certificate / Credit Application / Agreement...
  link       String? // external URL or storage reference
  notes      String?
  uploadedAt DateTime @default(now())

  @@index([customerId])
  @@map("customer_documents")
}

model CustomerBankAccount {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  bankName    String?
  accountName String?
  accountNumber String?
  swift       String?
  bankAddress String?
  sortOrder   Int      @default(0)

  @@index([customerId])
  @@map("customer_bank_accounts")
}

enum VendorType {
  SHIPPING_LINE
  HAULIER
  FORWARDING_AGENT
  CUSTOMS_BROKER
  WAREHOUSE
  COURIER
  AIRLINE
  SUPPLIER
  OTHER
}

model Vendor {
  id            String       @id @default(uuid())
  code          String       @unique // auto: VEN-0001
  name          String
  // ── Primary contact (denormalized; full list in contacts[]) ──
  contactPerson String?
  contactTitle  String?
  phone         String?
  email         String?
  mobile        String?
  officePhone   String?
  extension     String?
  whatsapp      String?
  preferredComm String? // EMAIL / PHONE / WHATSAPP / SMS
  // ── Company information ──
  address       String? // legacy single-line address (kept; full list in addresses[])
  vendorType    VendorType   @default(SUPPLIER)
  registrationNo String?
  taxId         String? // GST / VAT / SST number
  website       String?
  category      String? // free-text grouping
  servicesProvided String? // e.g. "Sea freight, haulage, customs"
  // ── Financial ──
  paymentTerm   String? // our payment terms with this vendor
  currency      String?      @default("MYR")
  creditLimit   Decimal?     @db.Decimal(14, 2) // credit they extend to us
  taxType       String?
  taxExempt     Boolean      @default(false)
  openingBalance Decimal?    @db.Decimal(14, 2)
  openingBalanceDate DateTime?
  // ── Procurement & operations ──
  assignedBuyerId String?
  assignedBuyer   User?      @relation("VendorBuyer", fields: [assignedBuyerId], references: [id], onDelete: SetNull)
  preferredMode   String? // Sea / Air / Land / Courier
  leadTimeDays    Int?
  deliveryTerms   String? // Incoterm or SLA
  minOrderValue   Decimal?   @db.Decimal(14, 2)
  // ── Accounting ──
  apAccount         String? // accounts-payable control account
  vendorAccountCode String?
  taxCategory       String?
  financeRemarks    String?
  // ── Compliance & lifecycle ──
  status        EntityStatus @default(ACTIVE)
  isPreferred   Boolean      @default(false)
  onboardedDate  DateTime?
  contractStart  DateTime?
  contractEnd    DateTime?
  insuranceExpiry DateTime?
  licenseNo      String?
  nextReviewDate DateTime?
  // ── Internal ──
  notes         String?
  warnings      String?
  blacklist     Boolean      @default(false)
  // ── System ──
  createdById   String?
  createdBy     User?     @relation("VendorCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById   String?
  updatedBy     User?     @relation("VendorUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedAt     DateTime? // soft delete — non-null means in the recycle bin
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  rates          VendorServiceRate[]
  ratings        VendorRating[]
  quotationItems QuotationItem[]
  jobs           Job[]
  contacts     VendorContact[]
  addresses    VendorAddress[]
  documents    VendorDocument[]
  bankAccounts VendorBankAccount[]

  @@index([name])
  @@index([deletedAt])
  @@index([assignedBuyerId])
  @@map("vendors")
}

model VendorContact {
  id        String  @id @default(uuid())
  vendorId  String
  vendor    Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name      String
  position  String?
  department String?
  mobile    String?
  phone     String?
  email     String?
  remarks   String?
  sortOrder Int     @default(0)

  @@index([vendorId])
  @@map("vendor_contacts")
}

model VendorAddress {
  id         String      @id @default(uuid())
  vendorId   String
  vendor     Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  type       AddressType @default(BILLING)
  line1      String?
  line2      String?
  city       String?
  state      String?
  postalCode String?
  country    String?     @default("Malaysia")
  isPrimary  Boolean     @default(false)
  sortOrder  Int         @default(0)

  @@index([vendorId])
  @@map("vendor_addresses")
}

model VendorDocument {
  id         String   @id @default(uuid())
  vendorId   String
  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name       String
  category   String?
  link       String?
  notes      String?
  uploadedAt DateTime @default(now())

  @@index([vendorId])
  @@map("vendor_documents")
}

model VendorBankAccount {
  id          String  @id @default(uuid())
  vendorId    String
  vendor      Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  bankName    String?
  accountName String?
  accountNumber String?
  swift       String?
  bankAddress String?
  sortOrder   Int     @default(0)

  @@index([vendorId])
  @@map("vendor_bank_accounts")
}

model Service {
  id          String       @id @default(uuid())
  code        String       @unique // auto: SVC-0001
  name        String       @unique // Air Freight, Sea Freight, ...
  description String?
  status      EntityStatus @default(ACTIVE)
  deletedAt   DateTime? // soft delete — non-null means in the recycle bin
  createdAt   DateTime     @default(now())

  rates          VendorServiceRate[]
  quotationItems QuotationItem[]

  @@index([deletedAt])
  @@map("services")
}

// ─────────────────────── Vendor service rates ───────────────────────

enum RateType {
  FIXED
  PER_KG
  PER_CBM
  PER_TON
  PER_TRIP
  PER_CONTAINER
  PER_SHIPMENT
  PER_HOUR
  PER_DAY
}

model VendorServiceRate {
  id            String    @id @default(uuid())
  vendorId      String
  // Restrict: rate history feeds historical job-cost audits — deleting a
  // vendor/service must not silently wipe it. Deactivate the vendor instead.
  vendor        Vendor    @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  serviceId     String
  service       Service   @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  origin        String?
  destination   String?
  country       String?
  state         String?
  containerType String? // e.g. 20FT / 40FT / 40HC for ocean FCL rates; null for non-container rates
  rateType      RateType  @default(FIXED)
  currency      String    @default("MYR")
  cost          Decimal   @db.Decimal(14, 4)
  minimumCharge Decimal?  @db.Decimal(14, 2)
  effectiveDate DateTime  @default(now())
  expiryDate    DateTime?
  remarks       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([serviceId, origin, destination])
  @@index([vendorId])
  @@map("vendor_service_rates")
}

// ─────────────────────────── Quotations ───────────────────────────

enum QuotationStatus {
  DRAFT
  SENT
  WON
  LOST
  CANCELLED
}

enum ApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

model Quotation {
  id            String          @id @default(uuid())
  quoteNumber   String          @unique // auto: QT-2026-0001
  customerId    String
  customer      Customer        @relation(fields: [customerId], references: [id])
  quoteDate     DateTime        @default(now())
  validityDate  DateTime?
  salesPersonId String?
  salesPerson   User?           @relation("SalesPerson", fields: [salesPersonId], references: [id])
  currency      String          @default("MYR")
  status        QuotationStatus @default(DRAFT)
  // Freight header shown on the printed quotation (Solid Xpress format):
  // RE line, ports, shipment/shipping terms. All optional free text.
  subject       String? // RE : QUOTATION FOR SEA EXPORT FROM PKG TO KUCHING DOOR
  yourRef       String? // customer's reference number
  attn          String? // attention person on the customer side
  pol           String? // Port of Loading, e.g. "PORT KLANG, MALAYSIA"
  pod           String? // Port of Discharge, e.g. "KUCHING, MALAYSIA"
  shipmentType  String? // "Full Container Load" / "LCL Cargo" / "Air Freight"...
  goods         String? // cargo description, e.g. "GEARBOX"
  shippingTerm  String? // Incoterm, e.g. "FREE ON BOARD"
  paymentTerm   String? // "CASH" / "NET 30"...
  // Costing engine outputs (denormalized totals for fast listing; recomputed on every item change)
  totalCost     Decimal         @default(0) @db.Decimal(14, 2)
  subtotalSell  Decimal         @default(0) @db.Decimal(14, 2)
  discountPct   Decimal         @default(0) @db.Decimal(7, 4)
  discountAmt   Decimal         @default(0) @db.Decimal(14, 2)
  serviceChargePct Decimal      @default(0) @db.Decimal(7, 4)
  miscCharge    Decimal         @default(0) @db.Decimal(14, 2)
  taxPct        Decimal         @default(0) @db.Decimal(7, 4)
  taxAmt        Decimal         @default(0) @db.Decimal(14, 2)
  sellingPrice  Decimal         @default(0) @db.Decimal(14, 2) // grand total
  grossProfit   Decimal         @default(0) @db.Decimal(14, 2)
  gpPercent     Decimal         @default(0) @db.Decimal(7, 4)
  remark        String?
  // Approval workflow: quotes at/above the configured base-currency threshold
  // need approval before SENT/WON (see approval.logic.ts). Edits re-trigger it.
  approvalStatus ApprovalStatus @default(NOT_REQUIRED)
  approvedById   String?
  approvedBy     User?          @relation("QuotationApprover", fields: [approvedById], references: [id], onDelete: Restrict)
  approvedAt     DateTime?
  approvalNote   String?
  deletedAt     DateTime? // soft delete — non-null means in the recycle bin
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  items     QuotationItem[]
  jobs      Job[]
  revisions QuotationRevision[]

  @@index([customerId])
  @@index([status])
  @@index([salesPersonId])
  @@index([deletedAt])
  @@map("quotations")
}

model QuotationItem {
  id           String    @id @default(uuid())
  quotationId  String
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  serviceId    String
  service      Service   @relation(fields: [serviceId], references: [id])
  vendorId     String?
  vendor       Vendor?   @relation(fields: [vendorId], references: [id])
  rateId       String? // source VendorServiceRate snapshot reference
  description  String?
  quantity     Decimal   @default(1) @db.Decimal(14, 4)
  unit         String? // KG / CBM / TRIP / CONTAINER...
  costCurrency String    @default("MYR")
  fxRate       Decimal   @default(1) @db.Decimal(14, 6) // costCurrency -> quotation currency
  unitCost     Decimal   @default(0) @db.Decimal(14, 4)
  minimumCharge Decimal? @db.Decimal(14, 2)
  markupPct    Decimal   @default(0) @db.Decimal(7, 4)
  unitSell     Decimal   @default(0) @db.Decimal(14, 4) // in quotation currency
  totalCost    Decimal   @default(0) @db.Decimal(14, 2) // in quotation currency
  totalSell    Decimal   @default(0) @db.Decimal(14, 2)
  grossProfit  Decimal   @default(0) @db.Decimal(14, 2)
  gpPercent    Decimal   @default(0) @db.Decimal(7, 4)
  // SST-exempt line (printed as tax code SVE 0%) — Malaysian service tax
  // does not apply to ocean freight, per the standard quotation T&C.
  taxExempt    Boolean   @default(false)
  sortOrder    Int       @default(0)

  @@index([quotationId])
  @@index([serviceId])
  @@index([vendorId])
  @@map("quotation_items")
}

// Immutable snapshot of a quotation's commercial terms taken before an edit,
// so a quote that was already SENT/WON keeps a record of exactly what the
// customer saw. `snapshot` holds the full header + line items as JSON.
model QuotationRevision {
  id           String    @id @default(uuid())
  quotationId  String
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  revision     Int // 1-based, increments per quotation
  status       String // the quotation status at snapshot time
  sellingPrice Decimal   @db.Decimal(14, 2)
  grossProfit  Decimal   @db.Decimal(14, 2)
  snapshot     Json // { header: {...}, items: [...] }
  createdById  String?
  createdBy    User?     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime  @default(now())

  @@unique([quotationId, revision])
  @@index([quotationId])
  @@map("quotation_revisions")
}

// ─────────────────────────── Jobs / Shipments ───────────────────────────

enum JobStatus {
  OPEN
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

model Job {
  id             String    @id @default(uuid())
  jobNumber      String    @unique // auto: JOB-2026-0001
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id])
  quotationId    String?
  quotation      Quotation? @relation(fields: [quotationId], references: [id])
  shipmentDate   DateTime?
  etd            DateTime?
  eta            DateTime?
  origin         String?
  destination    String?
  vendorId       String? // primary assigned vendor
  vendor         Vendor?   @relation(fields: [vendorId], references: [id])
  trackingNumber String?
  status         JobStatus @default(OPEN)
  actualCost     Decimal   @default(0) @db.Decimal(14, 2)
  actualRevenue  Decimal   @default(0) @db.Decimal(14, 2)
  profit         Decimal   @default(0) @db.Decimal(14, 2)
  currency       String    @default("MYR")
  notes          String?
  deletedAt      DateTime? // soft delete — non-null means in the recycle bin
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  documents JobDocument[]
  tracking  JobTrackingEvent[]
  invoices  Invoice[]

  // One quotation converts to at most one job. NULLs are treated as distinct
  // by Postgres, so manually-created jobs (no quotation) are unaffected.
  @@unique([quotationId])
  @@index([customerId])
  @@index([status])
  @@index([vendorId])
  @@index([deletedAt])
  @@map("jobs")
}

enum TrackingEventSource {
  SYSTEM // auto-recorded on status transition (see state-machine.ts)
  MANUAL // entered by an operator
}

// Timeline of a shipment's progress. Job.status is the current state;
// this table is the history of how it got there, so a Job detail view
// can show more than just "the current status" — the whole journey.
model JobTrackingEvent {
  id          String              @id @default(uuid())
  jobId       String
  job         Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status      String // free-form label, e.g. job status or a milestone like "Departed origin port"
  location    String?
  description String?
  occurredAt  DateTime            @default(now())
  source      TrackingEventSource @default(MANUAL)
  createdById String?
  // Restrict: this is an accountability trail — a user who recorded events
  // must be deactivated (isActive=false), never hard-deleted from under it.
  createdBy   User?               @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime            @default(now())

  @@index([jobId, occurredAt])
  @@map("job_tracking_events")
}

// ─────────────────────────── Billing / Invoices ───────────────────────────

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique // auto: INV-2026-0001
  jobId         String?
  // Restrict: a job with invoices must not be deletable — cancel it instead,
  // so the billing trail keeps its link to the work it billed.
  job           Job?          @relation(fields: [jobId], references: [id], onDelete: Restrict)
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  currency      String        @default("MYR")
  subtotal      Decimal       @default(0) @db.Decimal(14, 2)
  taxPct        Decimal       @default(0) @db.Decimal(7, 4)
  taxAmt        Decimal       @default(0) @db.Decimal(14, 2)
  totalAmount   Decimal       @default(0) @db.Decimal(14, 2)
  // Denormalized running total, kept in sync with payments in the same
  // transaction (see InvoicesService) — avoids summing payments on every read.
  amountPaid    Decimal       @default(0) @db.Decimal(14, 2)
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  notes         String?
  // Freight header printed on the tax invoice (Solid Xpress format). All
  // optional free text; ports/vessel/BL etc. are copied from the job/quote
  // on generation and stay editable while the invoice is DRAFT.
  billToCode      String? // customer AR code, e.g. "300-M0070"
  attn            String?
  salesman        String?
  terms           String? // payment terms, e.g. "CASH" / "NET 30"
  exRate          Decimal? @db.Decimal(14, 4) // display ex-rate on the invoice header
  pol             String?
  pod             String?
  finalDestination String?
  etd             DateTime?
  eta             DateTime?
  feederVessel    String? // F.VESSEL
  motherVessel    String? // M.VESSEL
  hblNo           String?
  oblNo           String?
  goods           String? // DESC. OF GOODS
  measurement     String? // MEAS./WEIGHT, e.g. "632.4000M3 / 61753.65KGS"
  containerInfo   String? // e.g. "10 X 40'HC"
  noOfPackages    String? // e.g. "14986 CARTONS"
  shipper         String?
  consignee       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  payments InvoicePayment[]
  items    InvoiceItem[]

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@index([jobId])
  @@map("invoices")
}

model InvoiceItem {
  id           String   @id @default(uuid())
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description  String
  unitPrice    Decimal  @default(0) @db.Decimal(14, 4) // in lineCurrency
  unit         String? // UOM: 40'HC / SHPT / CONT / M3...
  quantity     Decimal  @default(1) @db.Decimal(14, 4)
  lineCurrency String   @default("MYR") // the unit price currency shown on the row
  fxRate       Decimal  @default(1) @db.Decimal(14, 6) // lineCurrency -> invoice currency
  amount       Decimal  @default(0) @db.Decimal(14, 2) // qty × unitPrice × fx, excl tax, in invoice currency
  taxExempt    Boolean  @default(false) // SVE 0% (e.g. ocean freight) vs SV
  accNo        String? // freight account code, e.g. "500-004" / "030"
  sortOrder    Int      @default(0)

  @@index([invoiceId])
  @@map("invoice_items")
}

model InvoicePayment {
  id           String   @id @default(uuid())
  invoiceId    String
  // Restrict: payment records are the cash ledger — an invoice with payments
  // must never be hard-deleted (cancel/void flows handle corrections).
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  amount       Decimal  @db.Decimal(14, 2)
  paidAt       DateTime @default(now())
  method       String? // bank transfer, cheque, cash...
  reference    String?
  recordedById String?
  // Restrict: who recorded a cash payment must stay resolvable — deactivate
  // users instead of deleting them.
  recordedBy   User?    @relation(fields: [recordedById], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())

  @@index([invoiceId])
  @@map("invoice_payments")
}

model JobDocument {
  id           String   @id @default(uuid())
  jobId        String
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name         String
  category     String? // BL, Invoice, Permit, POD...
  url          String? // object storage key / external URL (link-based docs)
  // Local-volume storage: a uploaded binary lives at storedPath under UPLOAD_DIR.
  storedPath   String? // relative filename on the upload volume (UUID-based, never user input)
  originalName String?
  mimeType     String?
  sizeBytes    Int?
  extracted    Json? // structured fields from template extraction (see bl-extract.ts)
  uploadedAt   DateTime @default(now())

  @@index([jobId])
  @@map("job_documents")
}

// ─────────────────────────── Ratings (KPI-based) ───────────────────────────

// Weighted criteria are configurable via SettingKV (rating.vendor.weights / rating.customer.weights)

model VendorRating {
  id                  String   @id @default(uuid())
  vendorId            String
  vendor              Vendor   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  ratedById           String?
  ratedBy             User?    @relation(fields: [ratedById], references: [id])
  price               Int // 1..5
  serviceQuality      Int
  communication       Int
  deliveryPerformance Int
  reliability         Int
  responseSpeed       Int
  overallScore        Decimal  @db.Decimal(5, 2) // weighted, computed by service layer
  comment             String?
  createdAt           DateTime @default(now())

  @@index([vendorId])
  @@map("vendor_ratings")
}

model CustomerRating {
  id                String   @id @default(uuid())
  customerId        String
  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  ratedById         String?
  ratedBy           User?    @relation(fields: [ratedById], references: [id])
  paymentSpeed      Int
  profitability     Int
  repeatBusiness    Int
  communication     Int
  complaintHistory  Int // higher = fewer complaints
  businessPotential Int
  overallScore      Decimal  @db.Decimal(5, 2)
  comment           String?
  createdAt         DateTime @default(now())

  @@index([customerId])
  @@map("customer_ratings")
}

// ─────────────────────────── Supporting tables ───────────────────────────

model ExchangeRate {
  id            String   @id @default(uuid())
  baseCurrency  String // e.g. USD
  quoteCurrency String // e.g. MYR
  rate          Decimal  @db.Decimal(14, 6) // 1 base = rate quote
  effectiveDate DateTime @default(now())

  @@unique([baseCurrency, quoteCurrency, effectiveDate])
  @@map("exchange_rates")
}

// Configurable auto-numbering: CUST-0001, VEN-0001, QT-2026-0001, JOB-2026-0001, SVC-0001
model Sequence {
  key         String  @id // "customer" | "vendor" | "service" | "quotation" | "job"
  prefix      String
  padding     Int     @default(4)
  includeYear Boolean @default(false)
  nextValue   Int     @default(1)
  yearScope   Int? // current year when includeYear (reset counter on new year)

  @@map("sequences")
}

// Generic configuration store (rating weights, thresholds, company profile, defaults)
model SettingKV {
  key   String @id
  value Json

  @@map("settings")
}

enum NotificationType {
  QUOTATION_EXPIRY
  VENDOR_RATE_EXPIRY
  PAYMENT_DUE
  JOB_DELAY
  HIGH_COST
  LOW_MARGIN
  SYSTEM
}

model Notification {
  id         String           @id @default(uuid())
  type       NotificationType
  title      String
  message    String
  entityType String? // "quotation" | "job" | "rate" | ...
  entityId   String?
  userId     String? // null = broadcast to all
  user       User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  isRead     Boolean          @default(false)
  dedupeKey  String?          @unique // prevents duplicate alerts for same entity+type+period
  createdAt  DateTime         @default(now())

  @@index([userId, isRead])
  @@index([entityType, entityId])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String // CREATE / UPDATE / DELETE / LOGIN / LOGIN_FAILED / PERMISSIONS_CHANGE ...
  entityType String
  entityId   String?
  detail     Json?
  ip         String? // captured from request context for forensics
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@map("audit_logs")
}
