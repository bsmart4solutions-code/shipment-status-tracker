# PostgreSQL connection
DATABASE_URL="postgresql://erp:erp_dev_pw@localhost:5432/logistics_erp?schema=public"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="8h"

# API
PORT=4000
CORS_ORIGIN="http://localhost:3000"

# Base currency used by dashboard/P&L aggregation
BASE_CURRENCY="MYR"

# Directory for uploaded document binaries (mount to a volume in production —
# on Render's free tier this is NOT persisted; see deployment notes)
UPLOAD_DIR="./uploads"

# development | production | testing
NODE_ENV="development"

# error | warn | info | debug — use "info" in production to cut log noise
LOG_LEVEL="debug"
